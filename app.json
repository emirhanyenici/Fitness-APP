{
  "expo": {
    "name": "Zenova LifeScore",
    "slug": "zenova-lifescore",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "zenova-lifescore",
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      "expo-web-browser"
    ],
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D1526"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.zenova.lifescore",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Zenova uses the camera to snap photos of your meals so the AI can estimate their nutrition.",
        "NSPhotoLibraryUsageDescription": "Zenova needs access to your photo library so you can pick an existing meal photo for nutrition analysis or set a profile picture.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0D1526",
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.zenova.lifescore"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "a127855a-7ce0-4bb5-9640-7626a81c16a3"
      }
    },
    "owner": "emirhanync"
  }
}
