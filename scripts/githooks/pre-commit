#!/usr/bin/env bash
# Zenova LifeScore — pre-commit hook
# Blocks commits that leak secrets or violate core client/server boundaries.
# Runs from the repo root (aura-health). Exit 1 = commit blocked.

ROOT=$(git rev-parse --show-toplevel)
STAGED=$(git diff --cached --name-only --diff-filter=ACM)
ERRORS=0; WARNINGS=0

RED='\033[0;31m'; YELLOW='\033[1;33m'; GREEN='\033[0;32m'; NC='\033[0m'
err()  { echo -e "${RED}[BLOCK]${NC}  $1"; ERRORS=$((ERRORS+1)); }
warn() { echo -e "${YELLOW}[WARN]${NC}   $1"; WARNINGS=$((WARNINGS+1)); }
ok()   { echo -e "${GREEN}[OK]${NC}     $1"; }

echo "━━━ Zenova pre-commit ━━━"

# ── Block sensitive files ─────────────────────────────────────────────────────
for f in $STAGED; do
  case "$f" in
    .env.example) ;; # template with placeholders only — safe and meant to be committed
    .env|.env.*|*.key|*.pem|*.p12|*.keystore) err "Sensitive file staged: $f" ;;
  esac
done

# ── No AI secrets / service-role keys in client code ──────────────────────────
SECRET_PATTERNS=("sk-ant-" "sk-proj-" "Bearer ey[A-Za-z0-9]" "service_role")
for f in $STAGED; do
  if echo "$f" | grep -qE "^(app|components|hooks|stores|services)/" && echo "$f" | grep -qE "\.(ts|tsx|js|jsx)$"; then
    for pattern in "${SECRET_PATTERNS[@]}"; do
      if git show ":$f" 2>/dev/null | grep -qE "$pattern"; then
        err "Secret pattern '$pattern' in client file: $f"
      fi
    done
  fi
done

# ── AI keys must not be exposed via EXPO_PUBLIC_ ──────────────────────────────
for f in $STAGED; do
  if echo "$f" | grep -qE "\.env"; then
    if git show ":$f" 2>/dev/null | grep -qE "EXPO_PUBLIC_(ANTHROPIC|OPENAI|CLAUDE)"; then
      err "AI key via EXPO_PUBLIC_ in $f — call the edge function instead"
    fi
  fi
done

# ── No direct AI API calls from client code (must go through edge functions) ──
for f in $STAGED; do
  if echo "$f" | grep -qE "^(app|components|hooks|stores|services)/" && echo "$f" | grep -qE "\.(ts|tsx)$"; then
    if git show ":$f" 2>/dev/null | grep -qE "api\.anthropic\.com|api\.openai\.com"; then
      err "Direct AI API call in client: $f — use supabase/functions/"
    fi
  fi
done

# ── Zustand stores belong in stores/ (advisory) ───────────────────────────────
for f in $STAGED; do
  if echo "$f" | grep -qE "^(app|components)/" && echo "$f" | grep -qE "\.(ts|tsx)$"; then
    if git show ":$f" 2>/dev/null | grep -qE "from 'zustand'"; then
      warn "Zustand imported outside stores/: $f"
    fi
  fi
done

echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
if [ $ERRORS -gt 0 ]; then
  echo -e "${RED}COMMIT BLOCKED — $ERRORS error(s), $WARNINGS warning(s)${NC}"
  exit 1
elif [ $WARNINGS -gt 0 ]; then
  echo -e "${YELLOW}Commit allowed — $WARNINGS warning(s)${NC}"
else
  ok "All checks passed"
fi
exit 0
