# AURA Health — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Supabase (get from: https://supabase.com/dashboard/project/<project>/settings/api)
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Anthropic (used in Supabase Edge Functions only — should NOT be EXPO_PUBLIC_)
# Store this in Supabase Edge Function secrets, not here
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# USDA Food Database (https://fdc.nal.usda.gov/api-key-signup.html)
# WARNING: Move this to a server-side proxy — do not expose to client
EXPO_PUBLIC_USDA_API_KEY=your-usda-api-key-here

# RapidAPI (not currently used in production)
EXPO_PUBLIC_RAPIDAPI_KEY=your-rapidapi-key-here

# RevenueCat (https://app.revenuecat.com)
EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_your-ios-key-here
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=goog_your-android-key-here

# PostHog Analytics (https://us.posthog.com/settings/project-details)
EXPO_PUBLIC_POSTHOG_KEY=phc_your-project-key-here
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
